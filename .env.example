# Copy to ".env.local" (never commit .env.local). Use an Atlas database user — not your Atlas account password.
# URL-encode special characters in the password: https://www.mongodb.com/docs/manual/reference/connection-string/
#
# In Atlas: Network Access → allow your app IPs (or 0.0.0.0/0 only for quick dev, then tighten for production).
# Database Access → least-privilege user (read on this DB only if the app is read-only).
MONGODB_URI=mongodb+srv://DB_USERNAME:DB_PASSWORD@YOUR_CLUSTER_HOST.mongodb.net/?retryWrites=true&w=majority&appName=YOUR_APP_NAME

MONGODB_DB=picklespot
MONGODB_COLLECTION=courts
